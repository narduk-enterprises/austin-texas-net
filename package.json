{
  "name": "austin-texas-net",
  "version": "1.7.1",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "doppler run --project austin-texas-net --config dev -- pnpm --filter web dev",
    "build": "doppler run -- pnpm -r build",
    "deploy": "doppler run -- pnpm --filter web run deploy",
    "build:plugins": "pnpm --filter @narduk/eslint-config build",
    "prelint": "pnpm run build:plugins",
    "lint": "pnpm run prelint && turbo run lint",
    "typecheck": "turbo run typecheck",
    "quality": "turbo run quality",
    "setup": "npx tsx tools/init.ts",
    "update-layer": "npx tsx tools/update-layer.ts",
    "validate": "doppler run -- npx tsx tools/validate.ts",
    "doppler:sync-hub": "bash scripts/doppler-sync-hub.sh",
    "clean": "find . -type d \\( -name node_modules -o -name .nuxt -o -name .output -o -name .nitro -o -name .wrangler -o -name .turbo -o -name .data -o -name dist \\) -not -path './.git/*' -prune -exec rm -rf {} +",
    "clean:install": "pnpm run clean && pnpm install",
    "db:migrate": "pnpm --filter web run db:migrate",
    "db:studio": "pnpm --filter web run db:studio",
    "db:generate": "pnpm --filter web run db:generate",
    "db:seed-from-prod": "doppler run --project austin-texas-net --config dev -- pnpm --filter web run db:seed-from-prod",
    "generate:favicons": "node scripts/generate-favicons.mjs",
    "dev:kill": "sh scripts/dev-kill.sh"
  },
  "pnpm": {
    "overrides": {
      "nuxt-og-image": "6.0.0-beta.42",
      "esbuild": ">=0.25.0",
      "serialize-javascript": ">=7.0.3"
    },
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "better-sqlite3",
      "core-js",
      "esbuild",
      "protobufjs",
      "sharp",
      "unrs-resolver",
      "vue-demi",
      "workerd"
    ]
  },
  "volta": {
    "node": "22.22.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^22.19.13",
    "concurrently": "^9.2.1",
    "sharp": "^0.34.5",
    "turbo": "^2.8.12"
  }
}
