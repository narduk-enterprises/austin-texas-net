{
  "name": "austin-texas-net",
  "type": "module",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "npx nuxt typecheck",
    "deploy": "nuxt build && wrangler deploy",
    "generate:favicons": "node scripts/generate-favicons.mjs",
    "prelint": "test -f .nuxt/eslint.config.mjs || nuxt prepare",
    "lint": "eslint .",
    "quality": "pnpm run lint && pnpm run typecheck",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 execute austin-texas-net-db --local --file=drizzle/0000_initial_schema.sql",
    "db:studio": "drizzle-kit studio",
    "init": "npx jiti tools/init.ts"
  },
  "dependencies": {
    "@nuxt/content": "^3.11.2",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.3.0",
    "@nuxtjs/seo": "^3.4.0",
    "better-sqlite3": "^12.6.2",
    "chart.js": "^4.5.1",
    "drizzle-orm": "^0.45.1",
    "jose": "^6.1.3",
    "nuxt": "^4.3.0",
    "nuxt-schema-org": "^5.0.10",
    "posthog-js": "^1.205.0",
    "react": "^19.2.4",
    "tailwindcss": "^4.1.18",
    "vue": "^3.5.27",
    "vue-chartjs": "^5.3.3",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "@iconify-json/lucide": "^1.2.94",
    "@nuxt/eslint": "^1.15.2",
    "@nuxt/fonts": "^0.11.4",
    "@nuxtjs/robots": "^5.7.0",
    "@nuxtjs/sitemap": "^7.6.0",
    "@playwright/test": "^1.58.2",
    "@tavily/core": "^0.7.2",
    "@types/node": "^22.15.0",
    "@types/react": "^19.2.14",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "google-auth-library": "^10.6.1",
    "googleapis": "^171.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "nitro-cloudflare-dev": "^0.2.2",
    "nuxt-og-image": "^5.1.13",
    "openai": "^6.25.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript-eslint": "^8.56.1",
    "vue-eslint-parser": "^10.4.0",
    "wrangler": "^4.20.0",
    "tsup": "^8.5.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "overrides": {
    "@cloudflare/unenv-preset": "2.12.1",
    "vite": "npm:rolldown-vite@latest"
  },
  "volta": {
    "node": "22.14.0"
  }
}
